# ============================================================
#  Root .gitignore  –  bimsigner
# ============================================================

# ─── Node / Next.js ─────────────────────────────────────────
node_modules/
.next/
/out/
/build/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Python virtual environment ─────────────────────────────
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ─── Jupyter Notebook checkpoints ───────────────────────────
.ipynb_checkpoints/

# ─── Large ML / binary model files ──────────────────────────
*.h5
*.hdf5
*.pkl
*.pt
*.pth
*.onnx
*.pb
*.tflite
*.weights
*.bin

# ─── Data / dataset folders (add specific paths if needed) ──
data/
datasets/
*.csv
*.npy
*.npz

# ─── Logs & debug ───────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Environment / secrets ──────────────────────────────────
.env
.env.*
*.pem

# ─── Build / coverage ───────────────────────────────────────
/coverage
dist/
*.tsbuildinfo
next-env.d.ts

# ─── OS generated ───────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Editor / IDE ───────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── Vercel ─────────────────────────────────────────────────
.vercel
